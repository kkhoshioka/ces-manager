// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  // previewFeatures = ["driverAdapters"] 
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Customers Master
model Customer {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  address   String?
  phone     String?
  email     String?
  type      String?  // 'ユーザー', '修理業者', '機械メーカー', etc.
  
  // New fields
  representativeName        String?
  representativePhone       String?
  postalCode                String?
  fax                       String?
  invoiceRegistrationNumber String? // T+13digits
  invoicePostalCode         String?
  invoiceMailingAddress     String?
  paymentTerms              String? // 支払条件
  contactPerson             String? // 担当者名
  closingDate               String? // 締め日 (e.g., "20", "99" for end of month)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects         Project[]
  customerMachines CustomerMachine[]
  monthlyBillStatuses MonthlyBillStatus[]
  payments         Payment[]
  monthlyBillings  MonthlyBilling[]
  contacts         CustomerContact[]
}

model CustomerContact {
  id         Int      @id @default(autoincrement())
  customerId Int
  name       String
  position   String?  // 役職
  mobile     String?  // 携帯電話番号
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

// 2. Products/Services Master
model Product {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  partNumber     String?  // Manufacturer Part Number
  name           String
  category       String? // Deprecated: keep for now, sync with categoryId if possible
  categoryId     Int?    // Link to ProductCategory (Minor category)
  
  standardPrice  Decimal  @default(0)
  standardCost   Decimal  @default(0)
  stockQuantity  Int      @default(0)
  unit           String?  @default("個")
  
  // New alert fields
  alertEnabled   Boolean  @default(false)
  alertThreshold Int      @default(5)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projectDetails ProjectDetail[]
  purchases      Purchase[]
  productCategory ProductCategory? @relation(fields: [categoryId], references: [id])
}

// Monthly Inventory Snapshot
model MonthlyInventorySnapshot {
  id             Int      @id @default(autoincrement())
  year           Int
  month          Int
  productId      Int
  code           String
  partNumber     String?
  name           String
  categoryName   String?
  stockQuantity  Int
  unit           String?
  standardCost   Decimal
  standardPrice  Decimal
  totalCostValue Decimal  // stockQuantity * standardCost

  createdAt      DateTime @default(now())
  
  // Optional: keep relation to Product, though it might be deleted later
  // product        Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@unique([year, month, productId])
}

// 3. Owned Machines Master
model CustomerMachine {
  id           Int      @id @default(autoincrement())
  customerId   Int
  machineModel String
  serialNumber String
  manufacturingDate String? // 製造年月 (YYYY-MM)
  deliveryDate      DateTime? // 納入日
  lastInspectionDate DateTime? // 前回年次点検日
  nextInspectionDate DateTime? // 年次点検期限 (Calculated)
  enableInspectionAlert Boolean @default(true) // 年次点検アラート有効化
  notes        String?
  hourMeter    String?  // Current hour meter reading
  
  productCategoryId Int?
  category     ProductCategory? @relation(fields: [productCategoryId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer     Customer  @relation(fields: [customerId], references: [id])
  projects     Project[]

  @@unique([machineModel, serialNumber])
}

// 4. Projects Header
model Project {
  id                Int       @id @default(autoincrement())
  customerId        Int
  customerMachineId Int?
  
  customerContactName String? // New: 顧客担当者名
  
  type              String    @default("repair") // 'repair' or 'sales'
  
  // Snapshot fields
  machineModel      String?
  serialNumber      String?
  hourMeter         String? // Snapshot of hour meter at time of project
  
  orderDate         DateTime?
  completionDate    DateTime?
  status            String    @default("received") // received, diagnosing, in_progress, completed, delivered
  totalAmount       Decimal   @default(0)
  notes             String?
  
  // Rental specific fields
  rentalStartDate   DateTime?
  rentalEndDate     DateTime?
  actualReturnDate  DateTime?
  rentalStatus      String?   // reserved, rented, returned, cancelled
  
  // New Rental fields
  deliveryLocation  String?
  outboundHourMeter String?
  inboundHourMeter  String?

  // Status check fields
  isInvoiceIssued   Boolean   @default(false)
  isDeliveryNoteIssued Boolean @default(false) // New: Track if delivery note is issued
  isPaymentReceived Boolean   @default(false)
  paymentDate       DateTime?
  stockDeducted     Boolean   @default(false) // Track if inventory was deducted

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  customer          Customer         @relation(fields: [customerId], references: [id])
  customerMachine   CustomerMachine? @relation(fields: [customerMachineId], references: [id])
  
  details           ProjectDetail[]
  photos            ProjectPhoto[]
  quotations        Quotation[]
  purchases         Purchase[]
}

// 5. Project Details
model ProjectDetail {
  id              Int      @id @default(autoincrement())
  projectId       Int
  productId       Int?
  productCategoryId Int? // New: Link to Category directly for ad-hoc items
  
  lineType        String   // labor, part, outsourcing, other, travel
  department      String?  // New: 部門
  partNumber      String?  // New: 品番
  description     String
  supplier        String?
  supplierId      Int?     // Link to Supplier Master
  remarks         String?
  
  quantity        Decimal  @default(1)
  unitCost        Decimal  @default(0)
  unitPrice       Decimal  @default(0)
  
  // Calculated fields are not directly supported in Prisma schema as DB columns in SQLite easily without raw SQL, 
  // but we can compute them in application logic or use default values. 
  // For SQLite, generated columns are supported in newer versions but Prisma support might be limited.
  // We will store them as regular columns and calculate in app logic for now to be safe.
  amountCost      Decimal  @default(0) 
  amountSales     Decimal  @default(0)
  
  outsourcingCost Decimal  @default(0)
  
  outsourcingDetailType String? // labor, part, travel, etc.
  laborType       String?  // 'time' | 'fixed' (New)
  
  // Rental specific fields
  machineModel    String?
  serialNumber    String?
  rentalBillingType String? // 'daily' | 'monthly'
  rentalStartDate DateTime?
  rentalEndDate   DateTime?
  rentalBasicFee  Decimal  @default(0)
  rentalCompensationFee Decimal @default(0)
  rentalCompensationDays Decimal @default(1)

  date            DateTime? // Date of the expense/work (New)
  isTaxExempt     Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  product         Product? @relation(fields: [productId], references: [id])
  category        ProductCategory? @relation(fields: [productCategoryId], references: [id])
  supplierObj     Supplier? @relation(fields: [supplierId], references: [id])

  isInvoiceReceived Boolean  @default(false)
  isPaid            Boolean  @default(false)

  purchase          Purchase?
}

// 6. Project Photos
model ProjectPhoto {
  id          Int      @id @default(autoincrement())
  projectId   Int
  filePath    String
  fileName    String
  description String?
  uploadedAt  DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// 6.5 Purchases
model Purchase {
  id                Int      @id @default(autoincrement())
  date              DateTime // 仕入日
  supplierId        Int?
  supplierName      String?
  description       String
  category          String   // 仕入販売, 外注費, 在庫, その他
  department        String?  // 部門
  type              String?  // 種別 (lineType)
  partNumber        String?  // 品番
  quantity          Decimal
  unitCost          Decimal
  amount            Decimal
  isInvoiceReceived Boolean  @default(false)
  isPaid            Boolean  @default(false)

  projectId         Int?
  projectDetailId   Int?     @unique
  productId         Int?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project           Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectDetail     ProjectDetail? @relation(fields: [projectDetailId], references: [id], onDelete: Cascade)
  product           Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  supplierObj       Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
}

// 7. Masters
model ProductCategory {
  id        Int      @id @default(autoincrement())
  // Flattened structure as requested: Section (Department) -> Code -> Name
  section   String   // e.g. "新車販売", "レンタル"
  code      String?  @unique
  name      String
  sortOrder Int      @default(0) // Custom display order

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products  Product[]
  projectDetails ProjectDetail[]
  customerMachines CustomerMachine[]
}


model OperatingExpense {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  group         String?  // Grouping for display (e.g. "その他経費")
  unit          String?
  standardCost  Decimal  @default(0)
  standardPrice Decimal  @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  monthlyExpenses MonthlyExpense[]
}

model MonthlyExpense {
  id        Int      @id @default(autoincrement())
  year      Int
  month     Int
  expenseId Int
  amount    Decimal  @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expense   OperatingExpense @relation(fields: [expenseId], references: [id])
  @@unique([year, month, expenseId])
}

model TravelExpense {
  id        Int      @id @default(autoincrement())
  area      String   @unique // 地区
  fee       Decimal  @default(0) // 出張費（円）
  code      String?  @unique // コード
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemSetting {
  id            Int      @id @default(autoincrement())
  key           String   @unique // e.g., 'defaultLaborRate'
  value         String   // Store as string to be flexible (parse as Decimal/Int in app)
  description   String?
  updatedAt     DateTime @updatedAt
}

// 8. Suppliers Master
model Supplier {
  id            Int      @id @default(autoincrement())
  name          String
  code          String?  @unique
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  
  // New fields
  fax                       String?
  invoiceRegistrationNumber String?
  // Split Bank Info
  bankName      String? // 銀行名
  branchName    String? // 支店名
  accountType   String? // 口座種別 (普通/当座)
  accountNumber String? // 口座番号
  accountHolder String? // 名義
  paymentTerms              String? // 支払条件
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projectDetails ProjectDetail[]
  purchases      Purchase[]
}

// 9. User Profiles (Auth)


// 9. User Profiles (Auth)
model Profile {
  id        String   @id @default(uuid()) // Supabase User ID (UUID)
  email     String   @unique
  role      String   @default("staff") // 'admin' or 'staff'
  name      String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model MonthlyBillStatus {
  id          Int      @id @default(autoincrement())
  year        Int
  month       Int
  customerId  Int
  status      String   @default("draft") // draft, issued
  issuedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer @relation(fields: [customerId], references: [id])
  @@unique([year, month, customerId])
}


// 10. Quotations (Estimates)
model Quotation {
  id                Int       @id @default(autoincrement())
  projectId         Int
  
  quotationNumber   String?   // e.g. Q-20240206-001 (Optional, or auto-generated)
  issueDate         DateTime  @default(now())
  expirationDate    DateTime?
  
  totalAmount       Decimal   @default(0)
  taxAmount         Decimal   @default(0)
  
  status            String    @default("draft") // draft, sent, approved, rejected
  notes             String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  details           QuotationDetail[]
}

model QuotationDetail {
  id              Int      @id @default(autoincrement())
  quotationId     Int
  
  lineType        String   // labor, part, outsourcing, travel, etc.
  description     String
  quantity        Decimal  @default(1)
  unitPrice       Decimal  @default(0)
  unitCost        Decimal  @default(0) // Optional for quotation, but good to have
  
  date            DateTime? // Matches recent "date" addition
  travelType      String?
  outsourcingDetailType String?
  laborType       String? // 'time' | 'fixed' (New)
  
  quotation       Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  
  remarks         String?
  supplier        String?
  supplierId      Int?
  
  // Rental fields
  machineModel           String?
  serialNumber           String?
  rentalBillingType      String?
  rentalStartDate        DateTime?
  rentalEndDate          DateTime?
  rentalBasicFee         Decimal   @default(0)
  rentalCompensationFee  Decimal   @default(0)
  rentalCompensationDays Decimal   @default(0)
}

// 11. Payments & Billing
model Payment {
  id           Int      @id @default(autoincrement())
  customerId   Int
  amount       Decimal
  paymentDate  DateTime
  method       String?  // '振込', '現金', '手形', etc.
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  customer     Customer @relation(fields: [customerId], references: [id])
}

model MonthlyBilling {
  id               Int      @id @default(autoincrement())
  customerId       Int
  year             Int
  month            Int
  
  previousBalance  Decimal  @default(0) // 前回請求額
  paymentReceived  Decimal  @default(0) // 御入金額
  carryForward     Decimal  @default(0) // 繰越金額
  currentSales     Decimal  @default(0) // 今回御買上額 (税抜)
  taxAmount        Decimal  @default(0) // 消費税額
  currentBilling   Decimal  @default(0) // 今回御請求額
  
  closingDate      DateTime // 実際の締日
  isClosed         Boolean  @default(false)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  customer         Customer @relation(fields: [customerId], references: [id])
  
  @@unique([customerId, year, month])
}
